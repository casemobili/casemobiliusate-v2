---
import SchemaFaq from './SchemaFaq.astro';

interface Faq {
  q: string;
  a: string;
}

interface Props {
  items: Faq[];
  title?: string;
}

const { items, title = 'Domande frequenti' } = Astro.props;
---

<section class="my-12">
  <h2 style="margin-top:0">{title}</h2>
  <div class="space-y-3 mt-6">
    {items.map((f, i) => (
      <details class="rounded-lg border group" style="border-color:var(--color-linen-200);background-color:white" open={i === 0}>
        <summary class="cursor-pointer list-none px-5 py-4 flex items-center justify-between gap-4 font-medium">
          <span style="color:var(--color-forest-800)">{f.q}</span>
          <span class="shrink-0 transition-transform group-open:rotate-45 text-xl" style="color:var(--color-linen-500)">+</span>
        </summary>
        <div class="px-5 pb-5 leading-relaxed" style="color:var(--color-ink-700)" set:html={f.a} />
      </details>
    ))}
  </div>
</section>

<SchemaFaq items={items} />
