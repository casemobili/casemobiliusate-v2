---
interface Props {
  href: string;
  category: string;
  title: string;
  excerpt: string;
  date?: string;
  readTime?: string;
  image?: string;
}

const { href, category, title, excerpt, date, readTime, image } = Astro.props;

const categoryToHero: Record<string, { gradient: string; icon: string; color: string }> = {
  'Normativa': { gradient: 'linear-gradient(135deg,#2d5a3d,#4a7c59)', color: '#FAF7F0', icon: 'M30 25 L60 25 L60 65 L30 65 Z M40 35 L55 35 M40 45 L55 45 M40 55 L50 55' },
  'Prezzi': { gradient: 'linear-gradient(135deg,#c89b3c,#d4b365)', color: '#2d4f2d', icon: 'M45 20 L45 70 M30 30 C30 24 38 22 45 22 C52 22 60 24 60 30 C60 36 30 36 30 45 C30 52 38 54 45 54 C52 54 60 52 60 45' },
  'Marche': { gradient: 'linear-gradient(135deg,#2d5a3d,#1a4029)', color: '#d4b365', icon: 'M45 20 L51 36 L68 38 L55 50 L59 67 L45 58 L31 67 L35 50 L22 38 L39 36 Z' },
  'Trasporto': { gradient: 'linear-gradient(135deg,#c89b3c,#b8821e)', color: '#FAF7F0', icon: 'M18 50 L18 35 L40 35 L40 50 M40 42 L58 42 L70 50 L70 55 L18 55 L18 50 M27 55 C27 60 32 60 32 55 M55 55 C55 60 60 60 60 55' },
  'Vivere': { gradient: 'linear-gradient(135deg,#4a7c59,#2d5a3d)', color: '#e8d8b0', icon: 'M22 50 L45 28 L68 50 L68 68 L22 68 Z M40 68 L40 56 L50 56 L50 68' },
  'Dove Mettere': { gradient: 'linear-gradient(135deg,#2d5a3d,#c89b3c)', color: '#FAF7F0', icon: 'M45 18 C33 18 24 27 24 39 C24 54 45 72 45 72 C45 72 66 54 66 39 C66 27 57 18 45 18 Z M45 32 C49 32 52 35 52 39 C52 43 49 46 45 46 C41 46 38 43 38 39 C38 35 41 32 45 32 Z' },
  'Tipologie': { gradient: 'linear-gradient(135deg,#4a7c59,#d4b365)', color: '#FAF7F0', icon: 'M18 32 L36 32 L36 58 L18 58 Z M54 32 L72 32 L72 58 L54 58 Z M40 38 L50 38 M40 45 L50 45 M40 52 L50 52' },
  'Confronti & Tipologie': { gradient: 'linear-gradient(135deg,#4a7c59,#d4b365)', color: '#FAF7F0', icon: 'M18 32 L36 32 L36 58 L18 58 Z M54 32 L72 32 L72 58 L54 58 Z M40 38 L50 38 M40 45 L50 45 M40 52 L50 52' },
  'Guide Acquisto': { gradient: 'linear-gradient(135deg,#c89b3c,#d4b365)', color: '#2d4f2d', icon: 'M30 22 L60 22 L60 68 L30 68 Z M35 35 L55 35 M35 44 L55 44 M35 53 L48 53 M55 60 L63 50 L72 60' },
};

const hero = categoryToHero[category] ?? { gradient: 'linear-gradient(135deg,#2d5a3d,#c89b3c)', color: '#FAF7F0', icon: 'M45 20 L51 36 L68 38 L55 50 L59 67 L45 58 L31 67 L35 50 L22 38 L39 36 Z' };
---

<a href={href} class="block rounded-xl overflow-hidden no-underline border transition-all hover:shadow-lg" style="border-color:var(--color-linen-200);background-color:white">
  {image ? (
    <div class="aspect-[16/9]" style={`background-image:url(${image});background-size:cover;background-position:center;`}></div>
  ) : (
    <div class="aspect-[16/9]" style={`background:${hero.gradient};display:flex;align-items:center;justify-content:center;`}>
      <svg viewBox="0 0 90 90" width="60%" height="60%" fill="none" stroke={hero.color} stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.85">
        <path d={hero.icon}/>
      </svg>
    </div>
  )}
  <div class="p-5">
    <div class="text-xs uppercase tracking-wider font-semibold mb-2" style="color:var(--color-brass-700)">{category}</div>
    <h3 class="text-lg font-semibold m-0 leading-snug" style="font-family:var(--font-display);color:var(--color-forest-800)">{title}</h3>
    <p class="text-sm mt-2 leading-relaxed" style="color:var(--color-ink-700)">{excerpt}</p>
    <div class="flex items-center gap-3 mt-4 text-xs" style="color:var(--color-ink-500)">
      {date && <span>{date}</span>}
      {date && readTime && <span>·</span>}
      {readTime && <span>{readTime}</span>}
    </div>
  </div>
</a>
