---
interface Faq {
  q: string;
  a: string;
}

interface Props {
  items: Faq[];
}

const { items } = Astro.props;

const data = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<script type="application/ld+json" set:html={JSON.stringify(data)} />
