---
import { PILLARS, SITE } from '~/lib/site';

const path = Astro.url.pathname;
function isActive(href: string) {
  return path === href || path.startsWith(href + '/');
}
---

<header class="sticky top-0 z-40 backdrop-blur bg-paper/90 border-b" style="border-color:var(--color-linen-200)">
  <nav class="max-w-7xl mx-auto px-4 md:px-6 h-16 flex items-center justify-between gap-6">
    <a href="/" class="no-underline flex items-center gap-2.5" aria-label="CaseMobiliUsate.com — Home">
      <span class="inline-flex items-center justify-center rounded-sm" style="width:38px;height:38px;background-color:var(--color-forest-800)">
        <svg width="38" height="38" viewBox="0 0 64 64" fill="none" aria-hidden="true">
          <path d="M16 24 L32 14 L48 24" stroke="#D4B365" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M44 35 C44 27, 38 22, 32 22 C24 22, 19 28, 19 36 C19 44, 24 50, 32 50 C38 50, 44 45, 44 37" stroke="#D4B365" stroke-width="3.5" stroke-linecap="round" fill="none"/>
          <line x1="14" y1="56" x2="50" y2="56" stroke="#D4B365" stroke-width="1.5" stroke-linecap="round" opacity="0.6"/>
        </svg>
      </span>
      <span class="hidden sm:flex flex-col leading-none">
        <span class="font-semibold text-lg" style="font-family:var(--font-display);color:var(--color-forest-800);letter-spacing:-0.01em">CaseMobiliUsate</span>
        <span class="text-xs uppercase tracking-widest mt-0.5" style="color:var(--color-brass-600);font-family:var(--font-sans)">.com</span>
      </span>
    </a>

    <ul class="hidden lg:flex items-center gap-1 text-sm">
      {PILLARS.map((p) => (
        <li>
          <a
            href={`/${p.slug}`}
            class:list={[
              'px-3 py-2 rounded-md no-underline transition-colors',
              isActive(`/${p.slug}`) ? 'bg-forest-50 text-forest-800' : 'text-ink-700 hover:bg-linen-50',
            ]}
          >
            {p.short}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-2">
      <a href="/community" class="hidden md:inline-flex btn-secondary text-sm py-2 px-4">Community</a>
      <a href="/strumenti" class="hidden sm:inline-flex btn-primary text-sm py-2 px-4">Strumenti</a>
      <button id="menu-toggle" class="lg:hidden p-2 -mr-2" aria-label="Apri menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>
  </nav>

  <div id="mobile-menu" class="lg:hidden hidden border-t" style="border-color:var(--color-linen-200)">
    <ul class="max-w-7xl mx-auto px-4 py-3 space-y-1">
      {PILLARS.map((p) => (
        <li>
          <a href={`/${p.slug}`} class="block px-3 py-2 rounded-md no-underline text-ink-900 hover:bg-linen-50">{p.title}</a>
        </li>
      ))}
      <li><a href="/strumenti" class="block px-3 py-2 rounded-md no-underline">Strumenti</a></li>
      <li><a href="/community" class="block px-3 py-2 rounded-md no-underline">Community</a></li>
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
