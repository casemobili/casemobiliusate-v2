---
interface Props {
  title?: string;
  subtitle?: string;
  variant?: 'inline' | 'centered';
}

const {
  title = 'Resta aggiornato sul mondo delle case mobili',
  subtitle = 'Una mail al mese: novità normative, modelli del momento, occasioni segnalate. Niente spam.',
  variant = 'centered',
} = Astro.props;
---

<section class:list={[
  'rounded-2xl p-8 md:p-10 my-12 border',
  variant === 'centered' ? 'text-center' : '',
]} style="background-color:var(--color-linen-50);border-color:var(--color-linen-200)">
  <h3 style="margin-top:0">{title}</h3>
  <p class="text-base mt-2 mb-6" style="color:var(--color-ink-700)">{subtitle}</p>

  <form
    action="https://www.aweber.com/scripts/addlead.pl"
    method="post"
    class:list={[
      'flex flex-col sm:flex-row gap-3 max-w-xl',
      variant === 'centered' ? 'mx-auto' : '',
    ]}
  >
    <input type="hidden" name="meta_redirect_onlist" value="https://www.casemobiliusate.com/grazie" />
    <input type="hidden" name="meta_message" value="1" />
    <label class="sr-only" for="newsletter-email">Email</label>
    <input
      type="email"
      name="email"
      id="newsletter-email"
      required
      placeholder="La tua email"
      class="flex-1 px-4 py-3 rounded-md border"
      style="border-color:var(--color-linen-300);background-color:white"
    />
    <button type="submit" class="btn-accent">Iscriviti gratis</button>
  </form>

  <p class="text-xs mt-4" style="color:var(--color-ink-500)">
    Iscrivendoti accetti la nostra <a href="/privacy" class="underline">privacy policy</a>. Disiscrizione con un click in fondo a ogni email.
  </p>
</section>
