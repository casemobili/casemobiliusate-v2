---
import { PILLARS, SITE } from '~/lib/site';
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t" style="background-color:var(--color-forest-800);color:#e8eee8;border-color:var(--color-forest-700)">
  <div class="max-w-7xl mx-auto px-4 md:px-6 py-16">
    <div class="grid md:grid-cols-4 gap-8 mb-12">
      <div class="md:col-span-2">
        <div class="text-2xl font-semibold mb-3" style="font-family:var(--font-display);color:white">
          CaseMobili<span style="color:var(--color-linen-300)">Usate</span>.com
        </div>
        <p class="text-sm leading-relaxed" style="color:#c4d2c4">
          Il portale italiano di riferimento per chi cerca, valuta o vive in una casa mobile usata.
          Guide imparziali, dati reali, strumenti pratici. Vivere in libertà.
        </p>
        <div class="mt-6 flex gap-3">
          <a href={SITE.social.facebookGroup} target="_blank" rel="noopener" class="text-sm underline" style="color:#c4d2c4">Gruppo Facebook</a>
          <a href={SITE.social.instagram} target="_blank" rel="noopener" class="text-sm underline" style="color:#c4d2c4">Instagram</a>
          <a href={SITE.social.youtube} target="_blank" rel="noopener" class="text-sm underline" style="color:#c4d2c4">YouTube</a>
          <a href={SITE.social.reddit} target="_blank" rel="noopener" class="text-sm underline" style="color:#c4d2c4">Reddit</a>
        </div>
      </div>

      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider mb-4" style="color:white;font-family:var(--font-sans)">Esplora</h3>
        <ul class="space-y-2 text-sm">
          {PILLARS.slice(0, 4).map((p) => (
            <li><a href={`/${p.slug}`} class="no-underline hover:underline" style="color:#c4d2c4">{p.title}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider mb-4" style="color:white;font-family:var(--font-sans)">Approfondisci</h3>
        <ul class="space-y-2 text-sm">
          {PILLARS.slice(4).map((p) => (
            <li><a href={`/${p.slug}`} class="no-underline hover:underline" style="color:#c4d2c4">{p.title}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="border-t pt-8 flex flex-col md:flex-row gap-4 justify-between items-start text-sm" style="border-color:var(--color-forest-700);color:#a8b8a8">
      <div>
        © {year} CaseMobiliUsate.com — Una pubblicazione CMU Edizioni
        <div class="mt-1 text-xs">
          <a href="/chi-siamo" class="no-underline hover:underline" style="color:#a8b8a8">Chi siamo</a> ·
          <a href="/contatti" class="no-underline hover:underline" style="color:#a8b8a8">Contatti</a> ·
          <a href="/privacy" class="no-underline hover:underline" style="color:#a8b8a8">Privacy</a> ·
          <a href="/affiliate-disclaimer" class="no-underline hover:underline" style="color:#a8b8a8">Affiliate disclaimer</a> ·
          <a href="/admin/" class="no-underline hover:underline" style="color:#a8b8a8">Area riservata</a>
        </div>
      </div>
      <div class="text-xs italic" style="color:#a8b8a8">
        Sito tecnico indipendente. Nessuna affiliazione con dealer o produttori.
      </div>
    </div>
  </div>
</footer>
