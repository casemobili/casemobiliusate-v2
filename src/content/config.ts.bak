import { defineCollection, z } from 'astro:content';
import { glob } from 'astro/loaders';

const articoli = defineCollection({
  loader: glob({ pattern: '**/*.mdx', base: './src/content/articoli' }),
  schema: z.object({
    titolo: z.string(),
    sottotitolo: z.string().optional(),
    pillar: z.enum(['normativa', 'prezzi', 'marche', 'trasporto', 'vivere', 'dove-mettere', 'tipologie', 'guide-acquisto']),
    slug: z.string().optional(),
    focusKeyword: z.string().optional(),
    keywordsSecondarie: z.array(z.string()).optional().default([]),
    metaDescription: z.string(),
    coverImage: z.string().optional(),
    coverImageAlt: z.string().optional(),
    coverImageCredit: z.string().optional(),
    dataPubblicazione: z.coerce.date(),
    dataAggiornamento: z.coerce.date().optional(),
    autore: z.string().default('andrea-bressan'),
    readingTime: z.number().int().min(1).max(60).default(5),
    tldr: z.string().optional(),
    faq: z.array(z.object({
      domanda: z.string(),
      risposta: z.string(),
    })).optional().default([]),
    articoliCorrelati: z.array(z.string()).optional().default([]),
    noindex: z.boolean().default(false),
    legacyPath: z.string().optional(),
  }),
});

const pillar = defineCollection({
  loader: glob({ pattern: '**/*.mdx', base: './src/content/pillar' }),
  schema: z.object({
    titolo: z.string(),
    descrizione: z.string(),
    pillarSlug: z.enum(['normativa', 'prezzi', 'marche', 'trasporto', 'vivere', 'dove-mettere', 'tipologie', 'guide-acquisto']),
    focusKeyword: z.string().optional(),
    metaDescription: z.string().optional(),
    faq: z.array(z.object({ domanda: z.string(), risposta: z.string() })).optional().default([]),
    articoliInPrimoPiano: z.array(z.string()).optional().default([]),
  }),
});

const pagine = defineCollection({
  loader: glob({ pattern: '**/*.mdx', base: './src/content/pagine' }),
  schema: z.object({
    titolo: z.string(),
    metaDescription: z.string(),
    slug: z.string(),
    template: z.enum(['standard', 'wide', 'narrow']).default('standard'),
    noindex: z.boolean().default(false),
    showInFooter: z.boolean().default(false),
    showInHeader: z.boolean().default(false),
    ordine: z.number().default(99),
  }),
});

const autori = defineCollection({
  loader: glob({ pattern: '**/*.json', base: './src/content/autori' }),
  schema: z.object({
    nome: z.string(),
    ruolo: z.string(),
    bio: z.string(),
    avatar: z.string().optional(),
    isPseudonym: z.boolean().default(false),
    linkedin: z.string().optional(),
    expertise: z.array(z.string()).optional().default([]),
  }),
});

export const collections = { articoli, pillar, pagine, autori };
