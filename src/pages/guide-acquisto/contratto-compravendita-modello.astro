        <li><a href="/normativa">Normativa case mobili: panoramica</a></li>
        <li><a href="/dove-mettere/campeggi-aperti-tutto-anno">Campeggi aperti tutto l\'anno</a></li>
      </ul>

      <FbCommunityWidget variant="card" />

      <FaqAccordion items={faq} title="Domande frequenti sul contratto compravendita" />
    </div>
  </article>

