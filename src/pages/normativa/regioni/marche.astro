---
import BaseLayout from '~/layouts/BaseLayout.astro';
import SchemaBreadcrumb from '~/components/SchemaBreadcrumb.astro';
import SchemaArticle from '~/components/SchemaArticle.astro';
import FaqAccordion from '~/components/FaqAccordion.astro';
import Tldr from '~/components/Tldr.astro';
import FbCommunityWidget from '~/components/FbCommunityWidget.astro';

const url = '/normativa/regioni/marche';
const fullUrl = `https://www.casemobiliusate.com${url}`;
const title = 'Casa mobile nelle Marche: costa adriatica e zone (guida 2026)';
const description = 'Casa mobile nelle Marche 2026: costa adriatica (Senigallia, Numana, San Benedetto), Riviera del Conero, normativa regionale e prassi locali.';

const faq = [
  { q: 'Dove sono i campeggi nelle Marche?', a: 'Concentrazione: <strong>costa adriatica</strong> (Senigallia, Marotta, Pesaro, Civitanova Marche, Porto Sant\'Elpidio, San Benedetto del Tronto), <strong>Riviera del Conero</strong> (Numana, Sirolo, Portonovo). Aree interne: pochissimi campeggi. Totale ~15-20 strutture importanti.' },
  { q: 'Quanto costa una piazzola nelle Marche?', a: 'Range 2026: <strong>2.500–4.000 €/anno</strong>. Riviera del Conero (premium per scenografia): 3.000-4.000 €. Senigallia/Pesaro: 2.500-3.500 €. San Benedetto: 2.500-3.500 €. Generalmente accessibili rispetto a Veneto/Toscana costa.' },
  { q: 'La Riviera del Conero è speciale?', a: 'Sì. Numana, Sirolo, Portonovo si trovano in un\'area paesaggisticamente protetta (Parco Naturale del Conero) con vincoli stringenti. Pochi campeggi (~5), tutti con autorizzazione storica. Qualità strutture sopra media. Prezzi piazzola: 3.000-4.000 €/anno. Mare cristallino, baie selvagge.' },
  { q: 'Vincoli specifici delle Marche?', a: 'Vincoli paesaggistici sulla costa (Codice dei Beni Culturali) + Parco del Conero. Sismicità classe 2 in molte aree (terremoto 2016 ha colpito interno della regione). Aree Natura 2000 numerose (Furlo, Sibillini interno). Casa mobile fuori campeggio: difficile.' },
];
---

<BaseLayout title={title} description={description} ogType="article">
  <article class="max-w-7xl mx-auto px-4 md:px-6 py-8">
    <SchemaBreadcrumb items={[
      { name: 'Home', url: '/' },
      { name: 'Normativa', url: '/normativa' },
      { name: 'Regioni', url: '/normativa#normative-regionali' },
      { name: 'Marche', url },
    ]} />

    <header class="max-w-3xl">
      <div class="eyebrow mb-3">Normativa · Regione</div>
      <h1>{title}</h1>
      <p class="text-lg md:text-xl mt-6 leading-relaxed" style="color:var(--color-ink-700)">
        Marche: costa adriatica con concentrazione media di campeggi, Riviera del Conero come gioiello paesaggistico (e più costoso). Prezzi piazzola accessibili, ambiente "tradizionale famiglia italiana".
      </p>
      <div class="flex items-center gap-4 mt-6 text-sm" style="color:var(--color-ink-500)">
        <span>A cura di Andrea Bressan</span>
        <span>·</span>
        <span>Aggiornato il 29 aprile 2026</span>
        <span>·</span>
        <span>5 min di lettura</span>
      </div>
    </header>

    <div class="prose-article mt-12">
      <Tldr>
        <p class="m-0">Marche: ~15-20 campeggi, costa adriatica + Riviera del Conero. Costi piazzola: <strong>2.500–4.000 €/anno</strong>. Conero: scenografico ma vincolato, pochi campeggi premium. Sismicità classe 2 (interno colpito da terremoto 2016). Costa: tradizionale, accessibile.</p>
      </Tldr>

      <h2>Le 2 zone principali</h2>

      <h3>Costa adriatica nord (Senigallia, Marotta, Pesaro)</h3>
      <p>~7 strutture. Costi piazzola: 2.500-3.500 €/anno. Stagione: aprile-ottobre standard. Spiagge sabbiose lunghe, tradizione turismo balneare consolidata. Senigallia in particolare ha "Spiaggia di Velluto" (sabbia molto fine).</p>

      <h3>Riviera del Conero (Numana, Sirolo, Portonovo)</h3>
      <p>~5 strutture, tutte con autorizzazione storica per via del Parco Naturale. Costi piazzola: 3.000-4.000 €/anno (premium per scenografia). Mare cristallino, baie selvagge, ambiente unico nel medio Adriatico. Vincoli ambientali stringenti per nuove installazioni.</p>

      <h3>Costa adriatica sud (Civitanova Marche, Porto Sant'Elpidio, San Benedetto del Tronto)</h3>
      <p>~5 strutture. Costi piazzola: 2.500-3.500 €/anno. Atmosfera familiare, prezzi accessibili. San Benedetto: città balneare consolidata.</p>

      <h2>Specificità marchigiane</h2>
      <ul>
        <li><strong>Riviera del Conero</strong>: protezione paesaggistica ed ambientale, qualità elevata strutture esistenti, no nuove installazioni</li>
        <li><strong>Sismica classe 2</strong>: terremoto 2016 ha colpito l'interno (Sibillini, Visso, Camerino). Costa è meno colpita ma resta in zona sismica</li>
        <li><strong>Aree Natura 2000</strong>: Furlo, Sibillini interno, Conero. Pochi campeggi nelle aree parco</li>
        <li><strong>Tradizione "famiglia italiana"</strong>: turismo prevalentemente domestico, ambiente meno internazionale di Veneto/Toscana</li>
      </ul>

      <FbCommunityWidget variant="card" />

      <FaqAccordion items={faq} title="Domande frequenti su casa mobile nelle Marche" />
    </div>
  </article>

  <SchemaArticle title={title} description={description} datePublished="2026-04-29" dateModified="2026-04-29" url={fullUrl} />
</BaseLayout>
