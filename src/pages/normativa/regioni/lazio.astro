---
import BaseLayout from '~/layouts/BaseLayout.astro';
import SchemaBreadcrumb from '~/components/SchemaBreadcrumb.astro';
import SchemaArticle from '~/components/SchemaArticle.astro';
import FaqAccordion from '~/components/FaqAccordion.astro';
import Tldr from '~/components/Tldr.astro';
import FbCommunityWidget from '~/components/FbCommunityWidget.astro';

const url = '/normativa/regioni/lazio';
const fullUrl = `https://www.casemobiliusate.com${url}`;
const title = 'Casa mobile in Lazio: normativa, zone e prassi (guida 2026)';
const description = 'Casa mobile in Lazio 2026: normativa, costa pontina e nord (Sabaudia, Sperlonga, Civitavecchia), prassi locali frammentate per Comune e dove conviene davvero.';

const faq = [
  { q: 'Il Lazio ha una normativa specifica per le case mobili?', a: 'Segue la <strong>normativa nazionale</strong> con <em>LR 1/1986</em> (turismo) e regolamenti di settore aggiornati. La caratteristica del Lazio è che le <strong>prassi cambiano molto da Comune a Comune</strong>: alcuni costieri (Sabaudia, Sperlonga, Anzio) hanno tradizione consolidata, altri (interni o piccoli) possono essere meno preparati.' },
  { q: 'Dove sono i campeggi nel Lazio?', a: 'Concentrazione principale sulla <strong>costa pontina</strong> (Sabaudia, San Felice Circeo, Sperlonga, Terracina, Gaeta) e sulla <strong>costa nord</strong> (Tarquinia, Civitavecchia, Santa Marinella). Più sporadici in entroterra o sui laghi (Bracciano, Bolsena). Totale circa 40-50 strutture importanti.' },
  { q: 'Quanto costa una piazzola in Lazio?', a: 'Range 2026: <strong>2.500–4.500 €/anno</strong> in zone tipiche. Sabaudia/Circeo (premium per via del Parco del Circeo): 3.500–5.500 €. Costa nord: 2.500–4.000 €. Sperlonga e Gaeta: 3.000–4.500 €. Generalmente più accessibili dei prezzi Veneto/Toscana costa.' },
  { q: 'La residenza è ottenibile?', a: 'Sì in molti Comuni costieri ma con prassi <strong>frammentate</strong>. <strong>Sabaudia</strong> ha tradizione (parco Circeo + comunità open-air storica). <strong>Anzio, Nettuno</strong> con prassi rodate. <strong>Comuni piccoli o interni</strong>: dipende dal singolo, spesso serve insistere e produrre documentazione completa. Tempi medi: 60-90 giorni vs 30-60 del Veneto.' },
  { q: 'Vincoli specifici da conoscere nel Lazio?', a: '3 vincoli ricorrenti: <strong>1)</strong> Parco Nazionale del Circeo (Sabaudia, San Felice Circeo) — vincoli paesaggistici e ambientali importanti, ma campeggi esistenti autorizzati funzionano regolarmente; <strong>2)</strong> Aree archeologiche (Tarquinia, costa etrusca) — vincoli specifici sulla movimentazione del terreno; <strong>3)</strong> Zone sismiche di classe 2-3 (gran parte interno + pontina) — non vietano case mobili ma alcuni Comuni richiedono certificazioni aggiuntive.' },
];
---

<BaseLayout title={title} description={description} ogType="article">
  <article class="max-w-7xl mx-auto px-4 md:px-6 py-8">
    <SchemaBreadcrumb items={[
      { name: 'Home', url: '/' },
      { name: 'Normativa', url: '/normativa' },
      { name: 'Regioni', url: '/normativa#normative-regionali' },
      { name: 'Lazio', url },
    ]} />

    <header class="max-w-3xl">
      <div class="eyebrow mb-3">Normativa · Regione</div>
      <h1>{title}</h1>
      <p class="text-lg md:text-xl mt-6 leading-relaxed" style="color:var(--color-ink-700)">
        Il Lazio ha buona presenza di campeggi ma prassi locali più frammentate del Veneto o della Toscana. Costa pontina e costa nord sono le aree principali, con qualità e prezzi variabili. Ecco le regole, le zone, le prassi specifiche e i vincoli da conoscere.
      </p>
      <div class="flex items-center gap-4 mt-6 text-sm" style="color:var(--color-ink-500)">
        <span>A cura di Andrea Bressan</span>
        <span>·</span>
        <span>Aggiornato il 29 aprile 2026</span>
        <span>·</span>
        <span>6 min di lettura</span>
      </div>
    </header>

    <div class="grid lg:grid-cols-12 gap-12 mt-12">
      <div class="lg:col-span-8 prose-article" style="margin:0">
        <Tldr>
          <p class="m-0">Lazio: normativa nazionale + LR 1/1986. Prassi locali <strong>frammentate</strong> per Comune. Zone d'eccellenza: <strong>costa pontina</strong> (Sabaudia, Circeo, Sperlonga, Gaeta), <strong>costa nord</strong> (Tarquinia, Civitavecchia). 40-50 campeggi importanti. Costi piazzola: <strong>2.500–5.500 €/anno</strong>. Vincoli specifici: Parco Circeo, aree archeologiche, sismicità interno.</p>
        </Tldr>

        <h2>Le 2 zone principali</h2>

        <h3>Costa pontina (Sabaudia, Circeo, Sperlonga, Gaeta)</h3>
        <p>La concentrazione più alta. Caratteristiche:</p>
        <ul>
          <li>~25 campeggi importanti</li>
          <li>Sabaudia/Circeo: premium per via del Parco Nazionale del Circeo, costi 3.500–5.500 €/anno</li>
          <li>Sperlonga, Gaeta: medi, 3.000–4.500 €/anno</li>
          <li>Anzio, Nettuno: storici, prassi rodate, 2.500–4.000 €/anno</li>
          <li>Stagione: aprile-ottobre attivi, alcuni 12 mesi</li>
        </ul>

        <h3>Costa nord (Tarquinia, Civitavecchia, Santa Marinella)</h3>
        <p>Concentrazione media, prezzi più accessibili. Caratteristiche:</p>
        <ul>
          <li>~15 campeggi importanti</li>
          <li>Costi piazzola: 2.500–4.000 €/anno</li>
          <li>Vicinanza Roma (1-1,5 ore): comodo per residenti capitolini</li>
          <li>Vincoli archeologici (Tarquinia) da considerare</li>
        </ul>

        <h2>Le prassi locali per la residenza</h2>
        <p>Il Lazio è la regione con <strong>prassi più variabili</strong> tra Comuni. Sintetizzando:</p>
        <ul>
          <li><strong>Sabaudia</strong>: prassi consolidate, residenti stabili da anni, Comune collaborativo</li>
          <li><strong>Anzio, Nettuno</strong>: tradizione campeggio, residenza ottenibile</li>
          <li><strong>Sperlonga, Gaeta</strong>: prassi medie, dipende dal singolo iter</li>
          <li><strong>Comuni piccoli o interni</strong>: spesso serve insistere, produrre documentazione completa, eventualmente assistenza legale</li>
        </ul>
        <p>Tempi medi residenza: <strong>60-90 giorni</strong> contro i 30-60 di Veneto.</p>

        <h2>Vincoli specifici da conoscere</h2>
        <ul>
          <li><strong>Parco Nazionale del Circeo</strong>: vincoli paesaggistici e ambientali importanti. Campeggi esistenti autorizzati funzionano regolarmente, ma nuove installazioni fuori campeggio sono molto difficili</li>
          <li><strong>Aree archeologiche</strong> (Tarquinia, costa etrusca): vincoli specifici sulla movimentazione del terreno</li>
          <li><strong>Zone sismiche di classe 2-3</strong>: gran parte dell'interno + costa pontina sono in classe sismica 3, alcuni Comuni richiedono certificazioni aggiuntive sul fissaggio della casa mobile</li>
          <li><strong>Tutela laghi vulcanici</strong> (Bracciano, Bolsena, Vico): vincoli paesaggistici, campeggi esistenti rari</li>
        </ul>

        <FbCommunityWidget variant="card" />

        <FaqAccordion items={faq} title="Domande frequenti su casa mobile in Lazio" />
      </div>

      <aside class="lg:col-span-4 hidden lg:block">
        <div class="sticky top-20 space-y-6">
          <div class="rounded-sm border p-5" style="border-color:var(--color-linen-200);background-color:var(--color-linen-50)">
            <div class="eyebrow mb-2">Pillar di riferimento</div>
            <a href="/normativa" class="block font-semibold no-underline hover:underline" style="color:var(--color-forest-800)">Normativa & Permessi →</a>
          </div>
          <FbCommunityWidget variant="sidebar" />
        </div>
      </aside>
    </div>
  </article>

  <SchemaArticle title={title} description={description} datePublished="2026-04-29" dateModified="2026-04-29" url={fullUrl} />
</BaseLayout>
