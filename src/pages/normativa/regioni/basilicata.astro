---
import BaseLayout from '~/layouts/BaseLayout.astro';
import SchemaBreadcrumb from '~/components/SchemaBreadcrumb.astro';
import SchemaArticle from '~/components/SchemaArticle.astro';
import FaqAccordion from '~/components/FaqAccordion.astro';
import Tldr from '~/components/Tldr.astro';
import FbCommunityWidget from '~/components/FbCommunityWidget.astro';

const url = '/normativa/regioni/basilicata';
const fullUrl = `https://www.casemobiliusate.com${url}`;
const title = 'Casa mobile in Basilicata: due mari e Pollino (guida 2026)';
const description = 'Casa mobile in Basilicata 2026: Maratea (Tirreno), Metaponto (Ionio), Pollino e Sila. 8-10 campeggi, prezzi accessibili. Normativa e prassi locali.';

const faq = [
  { q: 'La Basilicata ha sia costa tirrenica che ionica?', a: 'Sì, è una delle pochissime regioni con due coste su due mari diversi. <strong>Tirreno</strong>: solo 30 km, costa rocciosa scenografica (Maratea — perla del Tirreno). <strong>Ionio</strong>: 40 km, costa sabbiosa lunga (Metaponto, Policoro, Marina di Pisticci). Distribuzione campeggi: ~3 sul Tirreno, ~5 sul Ionio, ~1-2 nell\'interno (Pollino).' },
  { q: 'Quanto costa una piazzola in Basilicata?', a: 'Range 2026: <strong>2.000–3.500 €/anno</strong>. Maratea (premium tirrenico): 3.000-3.500 €. Costa ionica (Metaponto, Policoro): 2.000-3.000 € (più accessibile). Pollino interno: 1.800-2.500 € (stagionale). Tra i più convenienti del sud.' },
  { q: 'Maratea o costa ionica?', a: 'Maratea è scenografica (costa di rocce e baie selvagge, "perla del Tirreno"), ma poche piazzole, molto isolata, accesso difficile. Costa ionica è più "tradizionale famiglia": spiagge sabbiose chilometriche, prezzi sotto, infrastruttura turistica più sviluppata. Per <strong>vacanza tranquilla scenografica</strong>: Maratea. Per <strong>famiglia con bambini, costo accessibile</strong>: Metaponto/Policoro.' },
  { q: 'Vincoli specifici lucani?', a: 'Vincoli paesaggistici importanti su Maratea (Costa di Maratea protetta) e Pollino (Parco Nazionale, il più grande d\'Italia). Sismicità classe 1 in molte aree (Vulture-Melfese, terremoto 1980 Irpinia ha colpito anche zona). Casa mobile fuori campeggio in zone vincolate: praticamente impossibile.' },
];
---

<BaseLayout title={title} description={description} ogType="article">
  <article class="max-w-7xl mx-auto px-4 md:px-6 py-8">
    <SchemaBreadcrumb items={[
      { name: 'Home', url: '/' },
      { name: 'Normativa', url: '/normativa' },
      { name: 'Regioni', url: '/normativa#normative-regionali' },
      { name: 'Basilicata', url },
    ]} />

    <header class="max-w-3xl">
      <div class="eyebrow mb-3">Normativa · Regione</div>
      <h1>{title}</h1>
      <p class="text-lg md:text-xl mt-6 leading-relaxed" style="color:var(--color-ink-700)">
        Basilicata: due coste (Tirreno scenografico + Ionio sabbioso), Parco Nazionale del Pollino, 8-10 campeggi. Prezzi tra i più accessibili del sud, infrastruttura turistica in crescita ultima decade. Sismicità alta, ma campeggio è scelta sicura.
      </p>
      <div class="flex items-center gap-4 mt-6 text-sm" style="color:var(--color-ink-500)">
        <span>A cura di Andrea Bressan</span>
        <span>·</span>
        <span>Aggiornato il 29 aprile 2026</span>
        <span>·</span>
        <span>4 min di lettura</span>
      </div>
    </header>

    <div class="prose-article mt-12">
      <Tldr>
        <p class="m-0">Basilicata: <strong>8-10 campeggi</strong>, due coste (<strong>Tirreno-Maratea</strong>, <strong>Ionio-Metaponto</strong>) + interno Pollino. Costi piazzola: <strong>2.000–3.500 €/anno</strong>. Maratea premium scenografico, Ionio accessibile famiglia. Sismicità classe 1, vincoli Parco Nazionale del Pollino. Buon rapporto qualità-prezzo per il sud.</p>
      </Tldr>

      <h2>Le 3 zone</h2>

      <h3>Costa Tirrenica (Maratea)</h3>
      <p>~3 strutture. Maratea — la perla del Tirreno — costa di 30 km di rocce, baie selvagge, mare cristallino. Costi piazzola: 3.000-3.500 €/anno. Stagione: aprile-ottobre. Ambiente premium, pochi posti, accesso da treno limitato (stazione di Maratea piccola). Scenografia unica nel sud.</p>

      <h3>Costa Ionica (Metaponto, Policoro, Marina di Pisticci)</h3>
      <p>~5 strutture. Costa sabbiosa lunga 40 km. Costi piazzola: 2.000-3.000 €/anno. Stagione: aprile-ottobre. Ambiente "tradizionale famiglia italiana", spiagge larghe, vicinanza siti archeologici della Magna Grecia (Metaponto). Accessibile da treno (linea adriatica + diramazioni).</p>

      <h3>Pollino interno</h3>
      <p>1-2 strutture, prevalentemente stagionali estive. Parco Nazionale del Pollino è il più grande d\'Italia (192.000 ettari). Costi piazzola: 1.800-2.500 €/anno. Adatto a turismo escursionistico, avifauna, trekking.</p>

      <h2>Specificità lucane</h2>
      <ul>
        <li><strong>Due mari</strong>: caratteristica unica con poche altre regioni (anche Calabria). Vantaggio: scegli il mare in base alla giornata di vento</li>
        <li><strong>Sismicità classe 1</strong> in molte aree (Vulture, terremoto 1980 ha colpito anche Basilicata interna). Casa mobile vantaggio sismico</li>
        <li><strong>Pollino</strong>: parco nazionale grande con vincoli importanti. Casa mobile fuori campeggio impossibile</li>
        <li><strong>Costo della vita basso</strong>: tra i più bassi d\'Italia. Vantaggio per pensionati</li>
        <li><strong>Aeroporti distanti</strong>: Bari (2h), Lamezia (2.5h), Napoli (3h). Trasporti figli/anziani onerosi</li>
        <li><strong>Crescita infrastruttura turistica ultima decade</strong>: prezzi piazzola in aumento ma ancora accessibili</li>
      </ul>

      <FbCommunityWidget variant="card" />

      <FaqAccordion items={faq} title="Domande frequenti su casa mobile in Basilicata" />
    </div>
  </article>

  <SchemaArticle title={title} description={description} datePublished="2026-04-29" dateModified="2026-04-29" url={fullUrl} />
</BaseLayout>
