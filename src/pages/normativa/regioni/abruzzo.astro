---
import BaseLayout from '~/layouts/BaseLayout.astro';
import SchemaBreadcrumb from '~/components/SchemaBreadcrumb.astro';
import SchemaArticle from '~/components/SchemaArticle.astro';
import FaqAccordion from '~/components/FaqAccordion.astro';
import Tldr from '~/components/Tldr.astro';
import FbCommunityWidget from '~/components/FbCommunityWidget.astro';

const url = '/normativa/regioni/abruzzo';
const fullUrl = `https://www.casemobiliusate.com${url}`;
const title = 'Casa mobile in Abruzzo: costa e parchi (guida 2026)';
const description = 'Casa mobile in Abruzzo 2026: costa adriatica (Pescara, Vasto, Roseto), parchi montani, normativa regionale, sismicità e prassi locali.';

const faq = [
  { q: 'Dove sono i campeggi in Abruzzo?', a: 'Concentrazione: <strong>costa adriatica</strong> (Pescara, Roseto degli Abruzzi, Pineto, Vasto, Silvi Marina, Martinsicuro). <strong>Parchi montani</strong> (Gran Sasso, Maiella): rare strutture, prevalentemente piccole e stagionali. Totale ~12-15 strutture importanti.' },
  { q: 'Quanto costa una piazzola in Abruzzo?', a: 'Range 2026: <strong>2.000–3.500 €/anno</strong>. Costa: 2.500-3.500 €. Aree montane: 1.800-2.500 € (stagionali). Tra i più accessibili d\'Italia per qualità/prezzo.' },
  { q: 'L\'Abruzzo è in zona sismica?', a: 'Sì, <strong>tra le più sismiche d\'Italia</strong>. Classe 1 in gran parte regione (terremoto L\'Aquila 2009, Amatrice 2016). Casa mobile in campeggio è ok (campeggio ha già le autorizzazioni), ma alcuni Comuni richiedono certificazioni aggiuntive sul fissaggio. Vantaggio: case mobili sono più sicure delle case in muratura in caso di sisma (struttura leggera, danni limitati).' },
  { q: 'Vincoli specifici abruzzesi?', a: '3 vincoli: <strong>1)</strong> Parchi nazionali (Gran Sasso, Maiella, Abruzzo Lazio Molise) — rare strutture nelle aree parco; <strong>2)</strong> Costa Teatina (parco regionale costiero) — vincoli paesaggistici stringenti; <strong>3)</strong> Aree archeologiche (Alba Fucens, Chieti) — vincoli specifici.' },
];
---

<BaseLayout title={title} description={description} ogType="article">
  <article class="max-w-7xl mx-auto px-4 md:px-6 py-8">
    <SchemaBreadcrumb items={[
      { name: 'Home', url: '/' },
      { name: 'Normativa', url: '/normativa' },
      { name: 'Regioni', url: '/normativa#normative-regionali' },
      { name: 'Abruzzo', url },
    ]} />

    <header class="max-w-3xl">
      <div class="eyebrow mb-3">Normativa · Regione</div>
      <h1>{title}</h1>
      <p class="text-lg md:text-xl mt-6 leading-relaxed" style="color:var(--color-ink-700)">
        Abruzzo: costa adriatica accessibile, parchi montani importanti (3 parchi nazionali). Sismicità tra le più alte d'Italia ma vantaggio paradossale per le case mobili (struttura leggera = meno danni in sisma).
      </p>
      <div class="flex items-center gap-4 mt-6 text-sm" style="color:var(--color-ink-500)">
        <span>A cura di Andrea Bressan</span>
        <span>·</span>
        <span>Aggiornato il 29 aprile 2026</span>
        <span>·</span>
        <span>5 min di lettura</span>
      </div>
    </header>

    <div class="prose-article mt-12">
      <Tldr>
        <p class="m-0">Abruzzo: ~12-15 campeggi, prevalentemente costa adriatica. Costi piazzola: <strong>2.000–3.500 €/anno</strong>. Sismicità classe 1 (tra le più alte d'Italia). 3 parchi nazionali importanti (Gran Sasso, Maiella, Abruzzo). Costa Teatina con vincoli paesaggistici stringenti.</p>
      </Tldr>

      <h2>Le 2 zone principali</h2>

      <h3>Costa adriatica (Pescara, Roseto, Pineto, Vasto, Silvi)</h3>
      <p>~10 strutture, tradizione balneare consolidata. Costi piazzola: 2.500-3.500 €/anno. Stagione: aprile-ottobre. Pescara: città balneare grande, infrastruttura completa. Roseto, Pineto, Silvi: tradizionale famiglia italiana, prezzi accessibili. Vasto: zona sud, costa rocciosa scenografica.</p>

      <h3>Parchi montani (Gran Sasso, Maiella, Abruzzo Lazio Molise)</h3>
      <p>~3-5 piccole strutture, prevalentemente stagionali estive (giugno-settembre). Costi piazzola: 1.800-2.500 €/anno. Adatte a turismo escursionistico. Per uso continuativo in zona alpina serve casa mobile all-season (isolamento maggiorato, tetto neve).</p>

      <h2>Sismicità: cosa devi sapere</h2>
      <p>L'Abruzzo è in <strong>classe sismica 1</strong> in gran parte del territorio (la più alta classe). Terremoti recenti: L'Aquila 2009, Amatrice-Norcia 2016. Implicazioni per casa mobile:</p>
      <ul>
        <li><strong>In campeggio autorizzato</strong>: nessun problema. Il campeggio ha già le valutazioni sismiche</li>
        <li><strong>Su terreno privato</strong>: alcuni Comuni richiedono certificazioni aggiuntive sul fissaggio della casa mobile</li>
        <li><strong>Vantaggio paradossale</strong>: in caso di sisma le case mobili sono <strong>più sicure</strong> delle case in muratura. Struttura leggera, peso ridotto = oscillazioni minime, pochi danni alle persone (anche se la struttura può subire danni cosmetici)</li>
        <li><strong>Polizze assicurazione</strong>: verifica copertura eventi sismici nella tua polizza casa mobile</li>
      </ul>

      <h2>Specificità abruzzesi</h2>
      <ul>
        <li><strong>3 parchi nazionali</strong>: Gran Sasso e Monti della Laga, Maiella, Abruzzo Lazio Molise. Quasi un terzo regione è area protetta. Casa mobile fuori campeggio in zone parco: praticamente impossibile</li>
        <li><strong>Costa Teatina</strong>: parco regionale costiero con vincoli paesaggistici importanti</li>
        <li><strong>Aree archeologiche</strong>: Alba Fucens, Chieti. Vincoli specifici sulla movimentazione terreno</li>
        <li><strong>Microclima</strong>: costa mite (Adriatico), interno alpino con inverni rigidi</li>
      </ul>

      <FbCommunityWidget variant="card" />

      <FaqAccordion items={faq} title="Domande frequenti su casa mobile in Abruzzo" />
    </div>
  </article>

  <SchemaArticle title={title} description={description} datePublished="2026-04-29" dateModified="2026-04-29" url={fullUrl} />
</BaseLayout>
