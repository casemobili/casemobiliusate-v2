---
import BaseLayout from '~/layouts/BaseLayout.astro';
import SchemaBreadcrumb from '~/components/SchemaBreadcrumb.astro';
import SchemaArticle from '~/components/SchemaArticle.astro';
import FaqAccordion from '~/components/FaqAccordion.astro';
import Tldr from '~/components/Tldr.astro';
import FbCommunityWidget from '~/components/FbCommunityWidget.astro';

const url = '/normativa/regioni/puglia';
const fullUrl = `https://www.casemobiliusate.com${url}`;
const title = 'Casa mobile in Puglia: Salento, Gargano e costa (guida 2026)';
const description = 'Casa mobile in Puglia 2026: Salento (Otranto, Gallipoli), Gargano, costa adriatica (Bari, Lesina), normativa regionale e prassi locali.';

const faq = [
  { q: 'Dove sono i campeggi in Puglia?', a: 'Concentrazione: <strong>Salento</strong> (Otranto, Gallipoli, Porto Cesareo, Torre dell\'Orso), <strong>Gargano</strong> (Vieste, Peschici, Mattinata), <strong>costa adriatica nord</strong> (Lesina, Manfredonia). Totale ~30 strutture importanti, in crescita negli ultimi 10 anni per il boom turistico Salento.' },
  { q: 'Quanto costa una piazzola in Puglia?', a: 'Range 2026: <strong>2.000–4.500 €/anno</strong>. Tra le più accessibili d\'Italia. Salento centrale (Gallipoli, Otranto): 2.500-4.500 €. Gargano (Vieste, Peschici): 2.000-3.500 €. Costa adriatica nord: 2.000-3.000 €. Località di moda (Pescoluse, Torre dell\'Orso): possono salire a 4.000-5.000 €.' },
  { q: 'La Puglia è adatta per uso annuale?', a: 'Sì, e ha un vantaggio chiave: <strong>clima mite</strong> (temperature invernali medie 10-12°C). Salento e Gargano hanno alcuni campeggi aperti 10-12 mesi. Stagione effettiva turistica 8-9 mesi, ma comfort di vita possibile tutto l\'anno con casa mobile standard. Prassi residenza variabili per Comune.' },
  { q: 'Vincoli specifici pugliesi?', a: '3 vincoli ricorrenti: <strong>1)</strong> Parco Nazionale del Gargano (vincoli ambientali importanti); <strong>2)</strong> aree archeologiche (Egnazia, Brindisi); <strong>3)</strong> sismicità classe 2-3 in molte aree (alcuni Comuni richiedono certificazioni aggiuntive sul fissaggio casa mobile).' },
];
---

<BaseLayout title={title} description={description} ogType="article">
  <article class="max-w-7xl mx-auto px-4 md:px-6 py-8">
    <SchemaBreadcrumb items={[
      { name: 'Home', url: '/' },
      { name: 'Normativa', url: '/normativa' },
      { name: 'Regioni', url: '/normativa#normative-regionali' },
      { name: 'Puglia', url },
    ]} />

    <header class="max-w-3xl">
      <div class="eyebrow mb-3">Normativa · Regione</div>
      <h1>{title}</h1>
      <p class="text-lg md:text-xl mt-6 leading-relaxed" style="color:var(--color-ink-700)">
        Puglia: in crescita per il turismo Salento dell'ultimo decennio. Costi piazzola tra i più accessibili d'Italia, clima mite per uso annuale. Ecco le 3 zone principali (Salento, Gargano, costa adriatica nord) e specificità.
      </p>
      <div class="flex items-center gap-4 mt-6 text-sm" style="color:var(--color-ink-500)">
        <span>A cura di Andrea Bressan</span>
        <span>·</span>
        <span>Aggiornato il 29 aprile 2026</span>
        <span>·</span>
        <span>5 min di lettura</span>
      </div>
    </header>

    <div class="prose-article mt-12">
      <Tldr>
        <p class="m-0">Puglia: ~30 campeggi, in crescita. Zone: <strong>Salento</strong> (Otranto, Gallipoli), <strong>Gargano</strong> (Vieste, Peschici), <strong>costa adriatica nord</strong>. Costi piazzola: <strong>2.000–4.500 €/anno</strong> (tra i più accessibili). Clima mite per uso annuale. Vincoli specifici: Parco Nazionale del Gargano, sismicità classe 2-3.</p>
      </Tldr>

      <h2>Le 3 zone principali</h2>

      <h3>Salento (Otranto, Gallipoli, Porto Cesareo, Torre dell'Orso)</h3>
      <p>Polo principale, in forte crescita ultima decade. ~15 strutture importanti. Costi piazzola: 2.500-4.500 €/anno. Stagione: aprile-ottobre con punte alta stagione luglio-agosto. Spiagge cristalline (Maldive del Salento, Pescoluse), borghi storici (Otranto, Gallipoli).</p>

      <h3>Gargano (Vieste, Peschici, Mattinata)</h3>
      <p>~10 strutture, ambiente più naturale (Parco Nazionale del Gargano). Costi piazzola: 2.000-3.500 €/anno (i più accessibili della costa adriatica). Stagione: aprile-ottobre. Trabucchi, baie, foreste umbra. Tradizione campeggio italiana storica.</p>

      <h3>Costa adriatica nord (Lesina, Manfredonia)</h3>
      <p>~5 strutture, dimensione minore. Costi piazzola: 2.000-3.000 €/anno (più accessibili in assoluto). Stagione: aprile-ottobre. Vicinanza Foresta Umbra, Promontorio del Gargano nord.</p>

      <h2>Vincoli specifici</h2>
      <ul>
        <li><strong>Parco Nazionale del Gargano</strong>: vincoli ambientali importanti, casa mobile fuori campeggio in zona parco quasi impossibile</li>
        <li><strong>Aree archeologiche</strong>: Egnazia, Brindisi, Otranto. Vincoli sulla movimentazione terreno</li>
        <li><strong>Sismicità classe 2-3</strong>: gran parte regione, alcuni Comuni richiedono certificazioni aggiuntive sul fissaggio</li>
        <li><strong>Vincoli paesaggistici costieri</strong>: 300 m da battigia tutelati, nuove installazioni fuori campeggio difficili</li>
      </ul>

      <h2>Crescita del settore</h2>
      <p>Negli ultimi 10 anni la Puglia ha visto <strong>raddoppiare le presenze open-air</strong> grazie al boom turistico Salento. Sono state aperte 8-10 nuove strutture (rare nelle altre regioni dove il numero è stabile). Effetto: prezzi piazzola più competitivi della media meridionale, qualità campeggi in aumento, comunità open-air in espansione.</p>

      <FbCommunityWidget variant="card" />

      <FaqAccordion items={faq} title="Domande frequenti su casa mobile in Puglia" />
    </div>
  </article>

  <SchemaArticle title={title} description={description} datePublished="2026-04-29" dateModified="2026-04-29" url={fullUrl} />
</BaseLayout>
