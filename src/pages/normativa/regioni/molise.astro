---
import BaseLayout from '~/layouts/BaseLayout.astro';
import SchemaBreadcrumb from '~/components/SchemaBreadcrumb.astro';
import SchemaArticle from '~/components/SchemaArticle.astro';
import FaqAccordion from '~/components/FaqAccordion.astro';
import Tldr from '~/components/Tldr.astro';
import FbCommunityWidget from '~/components/FbCommunityWidget.astro';

const url = '/normativa/regioni/molise';
const fullUrl = `https://www.casemobiliusate.com${url}`;
const title = 'Casa mobile in Molise: piccola costa adriatica (guida 2026)';
const description = 'Casa mobile in Molise 2026: 35 km di costa, Termoli, parchi interni, prezzi piazzola tra i più bassi d\'Italia. Normativa, prassi e zone.';

const faq = [
  { q: 'Il Molise ha campeggi adatti alla casa mobile?', a: 'Pochi ma presenti. Concentrazione: <strong>costa adriatica</strong> (Termoli, Petacciato, Campomarino, Montenero di Bisaccia), <strong>aree interne</strong> (Lago di Guardialfiera, Matese): rare. Totale <strong>4-6 strutture</strong> importanti. Il Molise ha 35 km di costa, è la 2ª regione italiana più piccola dopo la Valle d\'Aosta.' },
  { q: 'Quanto costa una piazzola in Molise?', a: 'Range 2026: <strong>1.800–2.800 €/anno</strong>. <strong>Tra i più accessibili d\'Italia</strong>. Termoli (la zona più sviluppata): 2.000-2.800 €. Costa minore (Campomarino, Petacciato): 1.800-2.500 €. Stagione: aprile-ottobre, alcuni 12 mesi.' },
  { q: 'È adatta per uso annuale o residenza?', a: 'Sì in alcuni campeggi di Termoli con residenti stabili (~10-30 famiglie totale). Inverni miti (8-12°C medi), no neve sulla costa. Vantaggio: costo della vita molto basso, comune di residenza Termoli ben servito (ospedale, scuole, supermercati). Svantaggio: aeroporto più vicino è Pescara (1.5h) o Bari (3h), trasporto figli/anziani può essere oneroso.' },
  { q: 'Vincoli specifici molisani?', a: 'Sismicità classe 2 in costa, classe 1 nell\'interno (terremoto Molise 2002 a San Giuliano di Puglia). Vincoli paesaggistici sulla costa (Codice dei Beni Culturali), Aree Natura 2000 (Foce del Trigno, Matese). Casa mobile fuori campeggio quasi impossibile. Sismicità: vantaggio paradossale (struttura leggera = pochi danni).' },
];
---

<BaseLayout title={title} description={description} ogType="article">
  <article class="max-w-7xl mx-auto px-4 md:px-6 py-8">
    <SchemaBreadcrumb items={[
      { name: 'Home', url: '/' },
      { name: 'Normativa', url: '/normativa' },
      { name: 'Regioni', url: '/normativa#normative-regionali' },
      { name: 'Molise', url },
    ]} />

    <header class="max-w-3xl">
      <div class="eyebrow mb-3">Normativa · Regione</div>
      <h1>{title}</h1>
      <p class="text-lg md:text-xl mt-6 leading-relaxed" style="color:var(--color-ink-700)">
        Molise: 35 km di costa adriatica, pochi campeggi ma prezzi piazzola tra i più bassi d\'Italia, costo della vita basso. La regione che spesso viene dimenticata ma offre rapporto qualità-prezzo competitivo per chi cerca tranquillità senza il sovraffollamento del Veneto o del Garda.
      </p>
      <div class="flex items-center gap-4 mt-6 text-sm" style="color:var(--color-ink-500)">
        <span>A cura di Andrea Bressan</span>
        <span>·</span>
        <span>Aggiornato il 29 aprile 2026</span>
        <span>·</span>
        <span>4 min di lettura</span>
      </div>
    </header>

    <div class="prose-article mt-12">
      <Tldr>
        <p class="m-0">Molise: <strong>4-6 campeggi</strong>, costa adriatica concentrata su Termoli. Costi piazzola: <strong>1.800–2.800 €/anno</strong> (tra i più bassi d\'Italia). Inverni miti sulla costa, costo vita basso. Sismicità classe 2 in costa, classe 1 interno. Adatta a chi cerca tranquillità senza grandi numeri turistici.</p>
      </Tldr>

      <h2>Le zone</h2>

      <h3>Costa adriatica (Termoli, Petacciato, Campomarino)</h3>
      <p>~4 strutture, prevalentemente piccole-medie. Termoli è la città principale con porto, treno, ospedale, infrastruttura completa. Costi piazzola: 2.000-2.800 €/anno. Stagione: aprile-ottobre standard, alcuni campeggi tutto-anno con residenti stabili.</p>

      <h3>Aree interne (Lago di Guardialfiera, Matese)</h3>
      <p>1-2 strutture, prevalentemente per turismo escursionistico. Stagione estiva (giugno-settembre). Costi 1.500-2.200 €/anno (pochi posti). Ambiente di montagna media, pochi servizi turistici.</p>

      <h2>Specificità molisane</h2>
      <ul>
        <li><strong>Costo della vita basso</strong>: prezzi alimentari, immobili, servizi tra i più bassi della penisola. Vantaggio per pensionati con budget limitato</li>
        <li><strong>Sismicità mista</strong>: costa classe 2 (moderata), interno classe 1 (alta, terremoto 2002). Casa mobile è vantaggio sismico (struttura leggera)</li>
        <li><strong>Trasporti limitati</strong>: aeroporto più vicino Pescara (1.5h auto) o Bari (3h). Treno Termoli ben servito ma ferma a metà sulla linea adriatica</li>
        <li><strong>Aree Natura 2000</strong>: Foce del Trigno, Matese. Casa mobile fuori campeggio in zone vincolate: impossibile</li>
        <li><strong>Comunità stabile piccola</strong>: residenti casa mobile sono ~50-100 totale regione. Vantaggio: prassi Comune snelle, conoscenza personale con direttori</li>
      </ul>

      <FbCommunityWidget variant="card" />

      <FaqAccordion items={faq} title="Domande frequenti su casa mobile in Molise" />
    </div>
  </article>

  <SchemaArticle title={title} description={description} datePublished="2026-04-29" dateModified="2026-04-29" url={fullUrl} />
</BaseLayout>
