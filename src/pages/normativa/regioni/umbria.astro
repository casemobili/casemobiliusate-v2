---
import BaseLayout from '~/layouts/BaseLayout.astro';
import SchemaBreadcrumb from '~/components/SchemaBreadcrumb.astro';
import SchemaArticle from '~/components/SchemaArticle.astro';
import FaqAccordion from '~/components/FaqAccordion.astro';
import Tldr from '~/components/Tldr.astro';
import FbCommunityWidget from '~/components/FbCommunityWidget.astro';

const url = '/normativa/regioni/umbria';
const fullUrl = `https://www.casemobiliusate.com${url}`;
const title = 'Casa mobile in Umbria: laghi e campagna (guida 2026)';
const description = 'Casa mobile in Umbria 2026: Lago Trasimeno, agriturismi rurali, vincoli paesaggistici e prassi locali in regione senza mare.';

const faq = [
  { q: 'L\'Umbria ha campeggi nonostante non abbia mare?', a: 'Sì, ma pochi e specifici. Concentrazione: <strong>Lago Trasimeno</strong> (Castiglione del Lago, Tuoro, San Feliciano), <strong>aree rurali</strong> con agriturismi attrezzati casa mobile. Totale ~8-10 strutture importanti.' },
  { q: 'Il Lago Trasimeno vale come zona per casa mobile?', a: 'Sì, è la zona principale umbra. ~5 campeggi tra Castiglione del Lago, Tuoro, San Feliciano, Passignano. Costi piazzola: 2.500-3.500 €/anno. Stagione: aprile-ottobre. Ambiente tranquillo, microclima mite, vicinanza Perugia/Cortona per servizi/cultura.' },
  { q: 'Casa mobile in agriturismo umbro: si può?', a: 'Sì, alcuni agriturismi umbri hanno autorizzazione specifica per ospitare case mobili. Caso particolare: serve agriturismo con autorizzazione + intesa specifica con Comune. Costi: 1.500-3.000 €/anno (più accessibili rispetto a campeggio). Vedi <a href="/dove-mettere/casa-mobile-agriturismo">la guida agriturismo</a>.' },
  { q: 'Vincoli specifici umbri?', a: 'Vincoli paesaggistici importanti (l\'Umbria ha tradizione di tutela paesaggio agricolo + storico). Aree Natura 2000 numerose (Trasimeno, Sibillini, Lago di Piediluco). Casa mobile fuori campeggio in zone vincolate: difficile. Sismicità classe 2 (terremoto Umbria-Marche 1997, Amatrice 2016 ha colpito Norcia).' },
];
---

<BaseLayout title={title} description={description} ogType="article">
  <article class="max-w-7xl mx-auto px-4 md:px-6 py-8">
    <SchemaBreadcrumb items={[
      { name: 'Home', url: '/' },
      { name: 'Normativa', url: '/normativa' },
      { name: 'Regioni', url: '/normativa#normative-regionali' },
      { name: 'Umbria', url },
    ]} />

    <header class="max-w-3xl">
      <div class="eyebrow mb-3">Normativa · Regione</div>
      <h1>{title}</h1>
      <p class="text-lg md:text-xl mt-6 leading-relaxed" style="color:var(--color-ink-700)">
        Umbria: regione senza mare ma con il Lago Trasimeno e una tradizione di agriturismi che a volte ospitano case mobili. Pochi campeggi, ambiente rurale, prezzi piazzola accessibili. Adatta a chi cerca tranquillità e cultura, non sole e mare.
      </p>
      <div class="flex items-center gap-4 mt-6 text-sm" style="color:var(--color-ink-500)">
        <span>A cura di Andrea Bressan</span>
        <span>·</span>
        <span>Aggiornato il 29 aprile 2026</span>
        <span>·</span>
        <span>4 min di lettura</span>
      </div>
    </header>

    <div class="prose-article mt-12">
      <Tldr>
        <p class="m-0">Umbria: ~8-10 campeggi, prevalentemente <strong>Lago Trasimeno</strong> + agriturismi rurali. Costi piazzola: <strong>2.500–3.500 €/anno</strong> (campeggi), <strong>1.500–3.000 €/anno</strong> (agriturismi). Ambiente rurale, vicinanza Perugia/Assisi/Cortona per cultura. Sismicità classe 2.</p>
      </Tldr>

      <h2>Lago Trasimeno: il polo umbro</h2>
      <p>~5 campeggi tra Castiglione del Lago, Tuoro, San Feliciano, Passignano. Caratteristiche:</p>
      <ul>
        <li>Costi piazzola: 2.500-3.500 €/anno</li>
        <li>Stagione: aprile-ottobre standard</li>
        <li>Lago di pesca tradizionale, ambiente "cartolina italiana"</li>
        <li>Vicinanza Perugia (40 min), Assisi (1h), Cortona (30 min)</li>
        <li>Ambiente meno turistico-massa di Garda o Maggiore</li>
      </ul>

      <h2>Agriturismi attrezzati casa mobile</h2>
      <p>Caso umbro particolare. Alcuni agriturismi della regione hanno ottenuto autorizzazione specifica del Comune per ospitare 1-3 case mobili come "alloggio integrativo" alle camere tradizionali. Caratteristiche:</p>
      <ul>
        <li>Numero strutture: 5-10 (variabile, alcuni anni più, altri meno)</li>
        <li>Costi piazzola: 1.500-3.000 €/anno (sotto la media campeggio)</li>
        <li>Ambiente molto rurale, immersi in vigneti, oliveti, campagna</li>
        <li>Servizi minori che campeggio (no piscina, ristorante interno limitato)</li>
        <li>Spesso uso stagionale aprile-ottobre</li>
      </ul>

      <h2>Specificità umbre</h2>
      <ul>
        <li><strong>Senza mare</strong>: l'Umbria è l'unica regione del centro-sud senza costa. Casa mobile = scelta "campagna/lago", non "vacanza balneare"</li>
        <li><strong>Vincoli paesaggistici importanti</strong>: l'Umbria ha forte tradizione tutela paesaggio agricolo + storico (Codice dei Beni Culturali + Piano Paesaggistico Regionale)</li>
        <li><strong>Aree Natura 2000</strong>: Trasimeno, Sibillini, Piediluco. Casa mobile fuori campeggio in zone protette: difficile</li>
        <li><strong>Sismicità classe 2</strong>: terremoto 1997 e 2016 hanno colpito la regione</li>
        <li><strong>Vicinanza Toscana</strong>: alcuni residenti scelgono Umbria per prezzi più accessibili rispetto Toscana confinante</li>
      </ul>

      <FbCommunityWidget variant="card" />

      <FaqAccordion items={faq} title="Domande frequenti su casa mobile in Umbria" />
    </div>
  </article>

  <SchemaArticle title={title} description={description} datePublished="2026-04-29" dateModified="2026-04-29" url={fullUrl} />
</BaseLayout>
