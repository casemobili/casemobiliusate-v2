---
import BaseLayout from '~/layouts/BaseLayout.astro';
import SchemaBreadcrumb from '~/components/SchemaBreadcrumb.astro';
import SchemaArticle from '~/components/SchemaArticle.astro';
import FaqAccordion from '~/components/FaqAccordion.astro';
import Tldr from '~/components/Tldr.astro';
import FbCommunityWidget from '~/components/FbCommunityWidget.astro';

const url = '/normativa/regioni/valle-aosta';
const fullUrl = `https://www.casemobiliusate.com${url}`;
const title = 'Casa mobile in Valle d\'Aosta: alpi e neve (guida 2026)';
const description = 'Casa mobile in Valle d\'Aosta 2026: 4-5 campeggi alpini, autonomia speciale, requisiti casa all-season + tetto neve. Normativa e specificità alpine.';

const faq = [
  { q: 'Quanti campeggi ha la Valle d\'Aosta?', a: 'Pochi: <strong>4-5 strutture</strong>, prevalentemente in fondovalle (Aosta, Sarre, Pré-Saint-Didier, Cogne). La regione più piccola d\'Italia (~3.260 km²) e con più alta percentuale di territorio montano (impossibile installare campeggio in alta quota per ovvie ragioni di accesso e clima).' },
  { q: 'Quanto costa una piazzola in Valle d\'Aosta?', a: 'Range 2026: <strong>2.500–3.800 €/anno</strong>. Stagionali estivi (giugno-settembre): 2.500-3.000 €. Tutto-anno con doppia stagione (estate + sci): 3.000-3.800 €. Vicinanza piste sci (Pila, Cervinia, Courmayeur) può rendere campeggio adatto anche per stagione invernale.' },
  { q: 'Posso usare casa mobile tutto l\'anno in Valle d\'Aosta?', a: 'Sì ma con casa mobile <strong>all-season specifica per alpi</strong>: isolamento ≥150 mm (vs 80-100 mm standard), tetto rinforzato per neve (carico 250 kg/m² vs 80 standard), riscaldamento autonomo a metano/legna integrato. Inverni rigidi (anche -15°C, 1-2 m neve in fondovalle, di più in altitudine). Casa mobile estiva standard NON è adatta: rischio crollo tetto e impianti idraulici congelati.' },
  { q: 'Vincoli specifici valdostani?', a: 'Autonomia speciale (Statuto regionale): la Valle d\'Aosta legifera autonomamente in materia urbanistica e turismo. Parchi nazionali (Gran Paradiso) e regionali (Mont Avic) coprono >30% del territorio. Casa mobile fuori campeggio in zone vincolate: praticamente impossibile. Sismica classe 4 (la più bassa, vantaggio).' },
];
---

<BaseLayout title={title} description={description} ogType="article">
  <article class="max-w-7xl mx-auto px-4 md:px-6 py-8">
    <SchemaBreadcrumb items={[
      { name: 'Home', url: '/' },
      { name: 'Normativa', url: '/normativa' },
      { name: 'Regioni', url: '/normativa#normative-regionali' },
      { name: 'Valle d\'Aosta', url },
    ]} />

    <header class="max-w-3xl">
      <div class="eyebrow mb-3">Normativa · Regione</div>
      <h1>{title}</h1>
      <p class="text-lg md:text-xl mt-6 leading-relaxed" style="color:var(--color-ink-700)">
        Valle d\'Aosta: la più piccola regione d\'Italia, fondovalle alpino con 4-5 campeggi. Autonomia speciale, parchi enormi, clima rigido. Per chi ama montagna autentica e scia, ma serve casa mobile all-season specifica.
      </p>
      <div class="flex items-center gap-4 mt-6 text-sm" style="color:var(--color-ink-500)">
        <span>A cura di Andrea Bressan</span>
        <span>·</span>
        <span>Aggiornato il 29 aprile 2026</span>
        <span>·</span>
        <span>4 min di lettura</span>
      </div>
    </header>

    <div class="prose-article mt-12">
      <Tldr>
        <p class="m-0">Valle d\'Aosta: <strong>4-5 campeggi</strong> in fondovalle (Aosta, Sarre, Pré-Saint-Didier, Cogne). Costi piazzola: <strong>2.500–3.800 €/anno</strong>. Per uso annuale serve casa mobile <strong>all-season alpina</strong> (isolamento 150 mm, tetto neve rinforzato 250 kg/m²). Autonomia speciale, parchi 30%+ territorio. Adatta a montagna+sci, non a chi cerca compromesso.</p>
      </Tldr>

      <h2>Le zone</h2>

      <h3>Aosta e dintorni (Aosta, Sarre)</h3>
      <p>~2 strutture, in fondovalle a 580-700 m. Costi piazzola: 2.500-3.500 €/anno. Vicinanza Pila (15 min funivia) per sci, Aosta capoluogo per servizi. Inverni rigidi (-5/-10°C medi, picchi -15°C), 0,5-1 m neve in stagione.</p>

      <h3>Pré-Saint-Didier (alta valle, vicino Courmayeur)</h3>
      <p>~1-2 strutture. A 1.000 m di altitudine, vicinanza Monte Bianco e impianti Courmayeur. Costi piazzola: 3.000-3.800 €/anno (premium per posizione). Inverni più rigidi: -10/-15°C medi, 1-2 m neve. Casa mobile all-season obbligatoria.</p>

      <h3>Cogne (Gran Paradiso)</h3>
      <p>1 struttura piccola. A 1.500 m, gateway al Parco Nazionale del Gran Paradiso. Stagione: prevalentemente estiva (giugno-settembre) per turismo escursionistico, alcuni accessi invernali per sci di fondo. Costi piazzola: 2.500-3.000 €/anno.</p>

      <h2>Casa mobile alpina: requisiti tecnici specifici</h2>
      <p>Standard alpino richiede:</p>
      <ul>
        <li><strong>Isolamento pareti e tetto ≥150 mm</strong> (lana di roccia o PIR), vs 80-100 mm casa mobile estiva</li>
        <li><strong>Tetto rinforzato</strong>: carico neve 250 kg/m² (zona alpina) vs 80 kg/m² (standard mediterraneo). Pendenza minima 25-30° per scarico naturale</li>
        <li><strong>Riscaldamento autonomo</strong>: stufa a legna o caldaia a metano integrata. Pannelli convettori elettrici NON bastano (consumi proibitivi -10°C esterno)</li>
        <li><strong>Doppi vetri ad alta efficienza</strong> (Uw ≤1.4)</li>
        <li><strong>Impianto idraulico antigelo</strong>: tubazioni interne ai mobili (non su pareti esterne), valvola di scarico per inverno con casa chiusa</li>
        <li><strong>Tettuccio di copertura aggiuntivo</strong> sopra la casa mobile (alcuni campeggi alpini lo richiedono per protezione totale)</li>
      </ul>

      <p>Costo extra rispetto a casa mobile estiva: 5.000-12.000 €. Marche specializzate alpine: <strong>Hutten</strong> (Austria), <strong>BBS Trois</strong> (Francia), alcuni modelli <strong>Riviera</strong> (Italia) certificati alpini.</p>

      <h2>Specificità valdostane</h2>
      <ul>
        <li><strong>Autonomia speciale</strong>: Valle d\'Aosta legifera autonomamente. Verifica sempre prassi locali presso Comune e ufficio regionale Turismo</li>
        <li><strong>Bilinguismo</strong>: italiano-francese. Documenti e prassi spesso disponibili in entrambe le lingue</li>
        <li><strong>Parchi enormi</strong>: Gran Paradiso (parco nazionale), Mont Avic (regionale). Vincoli stringenti, casa mobile fuori campeggio impossibile</li>
        <li><strong>Sismica classe 4</strong> (la più bassa d\'Italia): nessun problema sismico</li>
        <li><strong>Costo della vita medio-alto</strong>: la Valle è destinazione turistica premium, prezzi alimentari/servizi sopra media nazionale</li>
        <li><strong>Doppia stagione</strong>: sci dicembre-aprile + escursioni giugno-settembre. Mesi di transizione (maggio, ottobre-novembre) spesso "morti"</li>
      </ul>

      <FbCommunityWidget variant="card" />

      <FaqAccordion items={faq} title="Domande frequenti su casa mobile in Valle d\'Aosta" />
    </div>
  </article>

  <SchemaArticle title={title} description={description} datePublished="2026-04-29" dateModified="2026-04-29" url={fullUrl} />
</BaseLayout>
