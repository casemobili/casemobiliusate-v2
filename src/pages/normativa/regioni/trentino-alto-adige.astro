---
import BaseLayout from '~/layouts/BaseLayout.astro';
import SchemaBreadcrumb from '~/components/SchemaBreadcrumb.astro';
import SchemaArticle from '~/components/SchemaArticle.astro';
import FaqAccordion from '~/components/FaqAccordion.astro';
import Tldr from '~/components/Tldr.astro';
import FbCommunityWidget from '~/components/FbCommunityWidget.astro';

const url = '/normativa/regioni/trentino-alto-adige';
const fullUrl = `https://www.casemobiliusate.com${url}`;
const title = 'Casa mobile in Trentino-Alto Adige: zone alpine e vincoli (2026)';
const description = 'Casa mobile in Trentino-Alto Adige 2026: campeggi alpini, isolamento richiesto per uso annuale, normativa regionale autonoma e vincoli paesaggistici stringenti.';

const faq = [
  { q: 'Quanti campeggi ci sono in Trentino-Alto Adige?', a: '~25 strutture importanti, distribuite tra Trentino (15) e Alto Adige (10). Concentrazioni: <strong>Lago di Garda lato trentino</strong> (Riva, Torbole, Arco), <strong>valli dolomitiche</strong> (Val Pusteria, Val di Fassa, Val di Fiemme), <strong>Lago di Caldaro</strong>. Strutture mediamente piccole e di alta qualità (tradizione tedesco-austriaca).' },
  { q: 'Le case mobili in zona alpina sono adatte a uso annuale?', a: 'Solo con isolamento maggiorato. <strong>Casa mobile standard</strong> (60-80 mm pareti) in zona alpina invernale = consumi energetici insostenibili + comfort scarso. <strong>Casa mobile all-season</strong> (100-130 mm) o premium con classe energetica A (Crippa Concept, Willerby Lodge): possibile uso annuale. Tetto deve essere rinforzato per neve.' },
  { q: 'Quanto costa una piazzola in Trentino-Alto Adige?', a: 'Range 2026: <strong>3.000–5.500 €/anno</strong>. Garda trentino premium: 4.000-5.500 €. Valli dolomitiche: 3.000-4.500 €. Costi alti per scarsità spazio + qualità strutture sopra media. Alcuni campeggi aperti 12 mesi (per stagione sci dicembre-marzo + estate).' },
  { q: 'Vincoli paesaggistici alpini?', a: 'Molto stringenti. Le valli alpine hanno tutela paesaggistica forte (Codice dei Beni Culturali + leggi provinciali specifiche). Casa mobile fuori campeggio: praticamente impossibile. Casa mobile in campeggio autorizzato: nessun problema. La Provincia Autonoma di Bolzano (Alto Adige) ha leggi urbanistiche particolarmente severe per tutela paesaggio dolomitico.' },
];
---

<BaseLayout title={title} description={description} ogType="article">
  <article class="max-w-7xl mx-auto px-4 md:px-6 py-8">
    <SchemaBreadcrumb items={[
      { name: 'Home', url: '/' },
      { name: 'Normativa', url: '/normativa' },
      { name: 'Regioni', url: '/normativa#normative-regionali' },
      { name: 'Trentino-Alto Adige', url },
    ]} />

    <header class="max-w-3xl">
      <div class="eyebrow mb-3">Normativa · Regione</div>
      <h1>{title}</h1>
      <p class="text-lg md:text-xl mt-6 leading-relaxed" style="color:var(--color-ink-700)">
        Trentino-Alto Adige: zone alpine, qualità campeggi sopra media (tradizione tedesco-austriaca), ma per uso annuale serve casa mobile con isolamento maggiorato e tetto rinforzato per neve. Ecco le 2 zone principali (Garda trentino, valli dolomitiche).
      </p>
      <div class="flex items-center gap-4 mt-6 text-sm" style="color:var(--color-ink-500)">
        <span>A cura di Andrea Bressan</span>
        <span>·</span>
        <span>Aggiornato il 29 aprile 2026</span>
        <span>·</span>
        <span>5 min di lettura</span>
      </div>
    </header>

    <div class="prose-article mt-12">
      <Tldr>
        <p class="m-0">Trentino-Alto Adige: ~25 campeggi (Garda trentino + valli dolomitiche). Costi piazzola: <strong>3.000–5.500 €/anno</strong>. Qualità strutture sopra media (tradizione tedesco-austriaca). Per uso annuale: <strong>casa mobile all-season obbligatoria</strong> (isolamento maggiorato, tetto rinforzato neve). Vincoli paesaggistici alpini stringenti.</p>
      </Tldr>

      <h2>Le 2 zone principali</h2>

      <h3>Garda trentino (Riva del Garda, Torbole, Arco)</h3>
      <p>~10 strutture, ambiente lacustre con microclima mite. Costi piazzola: 4.000-5.500 €/anno (tra i più alti della regione). Stagione: 8-12 mesi (alcuni 12). Atmosfera tedesco-austriaca, infrastruttura sportiva (vela, windsurf, mountain bike). Riva e Torbole hanno residenti stabili.</p>

      <h3>Valli dolomitiche (Val Pusteria, Val di Fassa, Val di Fiemme, Val Gardena)</h3>
      <p>~15 strutture, prevalentemente alta quota (1.000-1.600 m). Costi piazzola: 3.000-4.500 €/anno. Stagione: principalmente estate (giugno-settembre) + qualche struttura per sci (dicembre-marzo). Per uso annuale serve casa mobile con isolamento ≥120 mm pareti, tetto carico neve maggiorato (~150 kg/m² minimo).</p>

      <h2>Specificità alpine</h2>
      <ul>
        <li><strong>Isolamento maggiorato obbligatorio</strong>: per uso invernale serve gamma all-season (IRM all-season, Willerby Lodge, Crippa Concept), no case standard</li>
        <li><strong>Tetto neve</strong>: case mobili in zone con nevicate ≥1 metro richiedono tetto rinforzato (carico fino a 200 kg/m²)</li>
        <li><strong>Tubature antigelo</strong>: tutte le tubazioni esterne devono essere tracciate e isolate. Senza, gelo invernale = scoppio = danni 1.000-3.000 €</li>
        <li><strong>Sapelli</strong> (sgombero neve sopra casa mobile): in inverno servono interventi periodici per evitare cedimenti tetto sotto peso neve</li>
        <li><strong>Vincoli paesaggistici</strong>: Provincia Autonoma di Bolzano ha leggi particolarmente severe per tutela paesaggio dolomitico. Fuori campeggio: praticamente impossibile installare</li>
      </ul>

      <h2>Provincia Autonoma e normativa</h2>
      <p>Trentino-Alto Adige ha <strong>2 Province Autonome</strong> (Trento e Bolzano) con competenza esclusiva su urbanistica. Leggi provinciali integrative al codice nazionale, generalmente più severe sulla tutela paesaggistica e ambientale. La <strong>Provincia di Bolzano</strong> in particolare ha standard alti su qualità costruttiva e isolamento (anche per case mobili in campeggio).</p>

      <FbCommunityWidget variant="card" />

      <FaqAccordion items={faq} title="Domande frequenti su casa mobile in Trentino-Alto Adige" />
    </div>
  </article>

  <SchemaArticle title={title} description={description} datePublished="2026-04-29" dateModified="2026-04-29" url={fullUrl} />
</BaseLayout>
