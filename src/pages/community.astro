---
import BaseLayout from '~/layouts/BaseLayout.astro';
import SchemaBreadcrumb from '~/components/SchemaBreadcrumb.astro';
import FbCommunityWidget from '~/components/FbCommunityWidget.astro';
import { SITE } from '~/lib/site';

const title = 'Community Casa Mobili Italia: gruppo Facebook, Instagram, YouTube';
const description = 'La community italiana delle case mobili: gruppo Facebook con migliaia di proprietari, canale YouTube, Instagram. Esperienze reali, annunci verificati.';
---

<BaseLayout title={title} description={description}>
  <div class="max-w-5xl mx-auto px-4 md:px-6 py-8">
    <SchemaBreadcrumb items={[{ name: 'Home', url: '/' }, { name: 'Community', url: '/community' }]} />

    <header class="text-center max-w-3xl mx-auto mb-12">
      <h1>La community italiana delle case mobili</h1>
      <p class="text-lg md:text-xl mt-6 leading-relaxed" style="color:var(--color-ink-700)">
        Migliaia di proprietari, futuri acquirenti, vacanzieri e curiosi. Una rete di esperienze reali su Facebook, Instagram, YouTube e Reddit.
      </p>
    </header>

    <FbCommunityWidget variant="banner" />

    <section class="grid md:grid-cols-2 gap-6 mt-12">
      <div class="p-6 rounded-xl border" style="border-color:var(--color-linen-200);background-color:white">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 rounded-full flex items-center justify-center text-white font-bold text-xl" style="background-color:#1877f2">f</div>
          <h3 class="m-0" style="font-family:var(--font-display)">Gruppo Facebook</h3>
        </div>
        <p class="text-sm mb-4" style="color:var(--color-ink-700)">
          Il cuore della community. Annunci, esperienze, domande, segnalazioni di truffe. Migliaia di membri attivi ogni giorno.
        </p>
        <a href={SITE.social.facebookGroup} target="_blank" rel="noopener" class="btn-primary text-sm">Unisciti al gruppo →</a>
      </div>

      <div class="p-6 rounded-xl border" style="border-color:var(--color-linen-200);background-color:white">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 rounded-full flex items-center justify-center text-white font-bold" style="background:linear-gradient(45deg,#f09433,#dc2743,#bc1888)">IG</div>
          <h3 class="m-0" style="font-family:var(--font-display)">Instagram</h3>
        </div>
        <p class="text-sm mb-4" style="color:var(--color-ink-700)">
          Foto, ispirazione, modelli, interni, allestimenti. Storie quotidiane di chi vive in casa mobile.
        </p>
        <a href={SITE.social.instagram} target="_blank" rel="noopener" class="btn-secondary text-sm">Seguici →</a>
      </div>

      <div class="p-6 rounded-xl border" style="border-color:var(--color-linen-200);background-color:white">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 rounded-full flex items-center justify-center text-white font-bold" style="background-color:#ff0000">▶</div>
          <h3 class="m-0" style="font-family:var(--font-display)">YouTube</h3>
        </div>
        <p class="text-sm mb-4" style="color:var(--color-ink-700)">
          Video tour di case mobili, interviste a proprietari, guide pratiche all'ispezione e al trasporto.
        </p>
        <a href={SITE.social.youtube} target="_blank" rel="noopener" class="btn-secondary text-sm">Iscriviti al canale →</a>
      </div>

      <div class="p-6 rounded-xl border" style="border-color:var(--color-linen-200);background-color:white">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 rounded-full flex items-center justify-center text-white font-bold" style="background-color:#ff4500">R</div>
          <h3 class="m-0" style="font-family:var(--font-display)">Reddit</h3>
        </div>
        <p class="text-sm mb-4" style="color:var(--color-ink-700)">
          Discussioni più tecniche, recensioni di modelli, dibattiti normativi. Adatto a chi cerca confronti approfonditi.
        </p>
        <a href={SITE.social.reddit} target="_blank" rel="noopener" class="btn-secondary text-sm">Vai a r/casemobili →</a>
      </div>
    </section>
  </div>
</BaseLayout>
