---
import { getCollection, render } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import SchemaBreadcrumb from '~/components/SchemaBreadcrumb.astro';

export async function getStaticPaths() {
  const pagine = await getCollection('pagine', ({ data }) => !data.noindex);
  return pagine.map((p) => ({
    params: { slug: p.data.slug },
    props: { pagina: p },
  }));
}

const { pagina } = Astro.props;
const { Content } = await render(pagina);
const data = pagina.data;
---

<BaseLayout title={data.titolo} description={data.metaDescription} noindex={data.noindex}>
  <div class="max-w-3xl mx-auto px-4 md:px-6 py-8 prose-article">
    <SchemaBreadcrumb items={[{ name: 'Home', url: '/' }, { name: data.breadcrumbName ?? data.titolo, url: `/${data.slug}` }]} />

    {data.eyebrow && <div class="eyebrow mb-3">{data.eyebrow}</div>}
    {data.h1 && <h1 set:html={data.h1.replace(/\n/g, '<br/>')} />}
    {!data.h1 && <h1>{data.titolo}</h1>}

    <Content />
  </div>
</BaseLayout>
